{
  "name": "qxc-rtt-bridge",
  "version": "1.0.0",
  "description": "QXC Serial RTT Bridge - WebSocket bridge for RTT debug probes",
  "type": "module",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "pkg": {
    "scripts": "dist/**/*.js",
    "outputPath": "release",
    "targets": [
      "node18-win-x64",
      "node18-linux-x64",
      "node18-macos-x64",
      "node18-macos-arm64"
    ]
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "pkg": "npm run build && pkg .",
    "pkg:win": "npm run build && pkg . --targets node18-win-x64",
    "pkg:all": "npm run build && pkg ."
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "esbuild": "^0.28.0",
    "pkg": "^5.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
